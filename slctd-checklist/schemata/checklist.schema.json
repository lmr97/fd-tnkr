{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "slctdChecklist",
    "description": "Describes structure of shift checklist items, with sections.",
    "type": "object",
    "required": [ "shift", "version", "sections" ],
    "properties": {
        "shift": { "$ref": "./checklistDefs.schema.json#/$defs/shift" },
        "version": { "type": "integer", "exclusiveMinimum": 0 },
        "sections": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [ "startBy", "dueBy", "tasksToDo" ],
                "properties": {
                    "startBy": { "$ref": "./checklistDefs.schema.json#/$defs/startBy" },
                    "dueBy": { "$ref": "./checklistDefs.schema.json#/$defs/dueBy" },
                    "tasksToDo": {
                        "description": "The tasks that should be completed between `startBy` and `dueBy` times.",
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": [ "description" ],
                            "properties": {
                                "shortName": { "type": "string" },
                                "description": { "type": "string" }
                            }
                        }
                    }
                }
            }
        }
    }
}
