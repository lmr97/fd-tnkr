{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$defs": {
        "dueBy": { 
            "description": "The time by which he tasks in `listItems` are to be completed, ideally.",
            "type": "string", 
            "format": "time",
            "examples": [
                "10:00-07:00",
                "07:00Z",
                "03:00+02:00"
            ]
        },
        "shift": { 
            "type": "string", 
            "enum": [ 
                "AM", 
                "PM", 
                "Audit" 
            ] 
        },
        "startBy": { 
            "description": "The time by which the tasks in `listItems` are to be started, ideally.",
            "type": "string", 
            "format": "time",
            "examples": [
                "10:00-07:00",
                "07:00Z",
                "03:00+02:00"
            ]
        }
    }
}